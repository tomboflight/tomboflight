{
  "expo": {
    "name": "Tomb of Light",
    "slug": "tomboflight-mobile",
    "scheme": "tomboflight",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tomboflight.mobile"
    },
    "android": {
      "package": "com.tomboflight.mobile"
    },
    "extra": {
      "apiBaseUrl": "https://tomboflight-api.onrender.com"
    }
  }
}
