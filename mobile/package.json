{
  "name": "tomboflight-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "build:dev:ios": "npx eas-cli build --profile development --platform ios",
    "build:dev:android": "npx eas-cli build --profile development --platform android",
    "build:preview:ios": "npx eas-cli build --profile preview --platform ios",
    "build:preview:android": "npx eas-cli build --profile preview --platform android",
    "build:prod:ios": "npx eas-cli build --profile production --platform ios",
    "build:prod:android": "npx eas-cli build --profile production --platform android",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "dependencies": {
    "expo": "~53.0.0",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-status-bar": "~2.2.3",
    "pretty-format": "29.7.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "~0.20.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~53.0.7",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  }
}
