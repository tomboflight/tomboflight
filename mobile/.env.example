# Tomb of Light mobile environment values
# Local same-Mac browser testing:
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
#
# Physical phone testing against local backend (replace with your Mac LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8000
#
# Hosted API fallback:
# EXPO_PUBLIC_API_BASE_URL=https://tomboflight-api.onrender.com
#
# Note: Expo web local origins (http://localhost:*) must be explicitly allowed by backend CORS.
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_ENV=development
