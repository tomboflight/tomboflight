APP_NAME="Tomb of Light API"
APP_VERSION="1.0.0"
ENVIRONMENT="development"

# Mongo
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="tomboflight"

# Auth / JWT
SECRET_KEY="change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"
CSRF_TOKEN_EXPIRE_MINUTES="120"

# Upload storage + scanning
UPLOAD_STORAGE_DIR="storage/uploads"
RENDER_DISK_MOUNT_PATH=""
UPLOAD_QUARANTINE_DIR="storage/quarantine"
UPLOAD_SCAN_COMMAND=""
UPLOAD_SCAN_HOOK=""
UPLOAD_SCAN_FAIL_CLOSED="false"
UPLOAD_ALLOW_ADMIN_QUARANTINE_OVERRIDE="false"
UPLOAD_MAX_IMAGE_MB="10"
UPLOAD_MAX_DOCUMENT_MB="25"
UPLOAD_IMAGE_CONTENT_TYPES="image/jpeg,image/png,image/webp"
UPLOAD_DOCUMENT_CONTENT_TYPES="application/pdf,image/jpeg,image/png,image/webp"

# R2 / object storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT_URL=""
R2_REGION="auto"
R2_BUCKET=""
R2_PRIVATE_BUCKET=""
R2_METADATA_BUCKET=""
R2_POSTER_BUCKET=""
R2_FORCE_PATH_STYLE="true"
PUBLIC_STORAGE_DIR="storage/public"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=""
STRIPE_BILLING_PORTAL_RETURN_URL="https://tomboflight.com/billing.html"

# Mint runtime flags + chain config
NFT_MINT_ENABLED="false"
NFT_ORG_MINT_ENABLED="false"
NFT_AUTO_MINT_ON_REVIEW_ENABLED="false"
NFT_CHAIN="base-mainnet"
NFT_RPC_URL=""
NFT_CONTRACT_ADDRESS=""
NFT_CONTRACT_ABI_JSON=""
NFT_MINTER_PRIVATE_KEY=""
NFT_DEFAULT_RECIPIENT_WALLET=""
HASH_SALT=""
METADATA_BASE_URL="https://metadata.tomboflight.com/v1"
POSTER_BASE_URL="https://posters.tomboflight.com/v1"
PUBLIC_TOKEN_EXTERNAL_BASE_URL="https://tomboflight-api.onrender.com/tokens"

# Email / Postmark (optional)
POSTMARK_SERVER_TOKEN=""
POSTMARK_SERVER_TOKEN_FILE=""
POSTMARK_FROM_EMAIL="admin@tomboflight.com"
POSTMARK_FROM_NAME="Tomb of Light Security"
POSTMARK_MESSAGE_STREAM="outbound"
